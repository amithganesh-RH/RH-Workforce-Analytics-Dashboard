<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>

  <!-- Unique identifier for this job -->
  <key>Label</key>
  <string>com.redesignhealth.deel-sync</string>

  <!-- Command to run -->
  <key>ProgramArguments</key>
  <array>
    <string>/usr/local/bin/node</string>
    <string>/Users/amith.ganesh/Projects/Redesign-Health-Workforce-Analytics-Dashboard/sync.js</string>
  </array>

  <!-- Working directory (so .env is found) -->
  <key>WorkingDirectory</key>
  <string>/Users/amith.ganesh/Projects/Redesign-Health-Workforce-Analytics-Dashboard</string>

  <!-- Run daily at 7:00 AM -->
  <key>StartCalendarInterval</key>
  <dict>
    <key>Hour</key>
    <integer>7</integer>
    <key>Minute</key>
    <integer>0</integer>
  </dict>

  <!-- Log output -->
  <key>StandardOutPath</key>
  <string>/Users/amith.ganesh/Projects/Redesign-Health-Workforce-Analytics-Dashboard/sync.log</string>
  <key>StandardErrorPath</key>
  <string>/Users/amith.ganesh/Projects/Redesign-Health-Workforce-Analytics-Dashboard/sync.log</string>

  <!-- Don't run immediately on load (only on schedule) -->
  <key>RunAtLoad</key>
  <false/>

</dict>
</plist>
